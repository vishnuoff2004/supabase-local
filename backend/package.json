{
  "name": "travel-agency-backend",
  "version": "1.0.0",
  "description": "Travel Agency Services Platform — Backend API",
  "main": "src/server.js",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "test": "jest --forceExit --detectOpenHandles",
    "test:watch": "jest --watch",
    "migrate": "npx sequelize-cli db:migrate",
    "migrate:undo": "npx sequelize-cli db:migrate:undo",
    "migrate:undo:all": "npx sequelize-cli db:migrate:undo:all",
    "seed": "npx sequelize-cli db:seed:all",
    "seed:undo": "npx sequelize-cli db:seed:undo:all",
    "db:reset": "npx sequelize-cli db:migrate:undo:all && npx sequelize-cli db:migrate && npx sequelize-cli db:seed:all"
  },
  "dependencies": {
    "@sentry/node": "^10.57.0",
    "@sentry/tracing": "^7.120.4",
    "@socket.io/redis-adapter": "^8.3.0",
    "@supabase/supabase-js": "^2.108.2",
    "algoliasearch": "^5.54.0",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.78.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "ioredis": "^5.11.1",
    "minio": "^8.0.7",
    "multer": "^2.1.1",
    "nodemailer": "^9.0.1",
    "pg": "^8.22.0",
    "prom-client": "^15.1.3",
    "redis": "^6.0.0",
    "sequelize": "^6.37.3",
    "socket.io": "^4.8.3",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "jest": "^29.7.0",
    "jsonwebtoken": "^9.0.3",
    "nodemon": "^3.1.0",
    "sequelize-cli": "^6.6.5",
    "socket.io-client": "^4.8.3",
    "supertest": "^7.2.2"
  },
  "jest": {
    "testEnvironment": "node",
    "testTimeout": 120000,
    "setupFiles": ["dotenv/config"],
    "maxWorkers": 1,
    "coveragePathIgnorePatterns": [
      "/node_modules/"
    ]
  },
  "keywords": [],
  "author": "",
  "license": "ISC"
}
