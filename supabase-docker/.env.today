# ═══════════════════════════════════════════════════════════════════════════
# SUPABASE LOCAL DEV ENVIRONMENT  ──  Created 2026-06-23
# ═══════════════════════════════════════════════════════════════════════════
#
# 📥 COPY THIS FILE:
#   Copy this file to .env to activate it:
#     copy .env.today .env
#
# 🚀 START ALL SERVICES:
#   cd supabase-docker
#   docker compose up -d
#
# 🛑 STOP ALL SERVICES:
#   docker compose down
#
# 🧹 WIPE & RESET (deletes volumes):
#   docker compose down -v
#
# ═══════════════════════════════════════════════════════════════════════════
# SERVICE URLS
# ═══════════════════════════════════════════════════════════════════════════
#
#  Service          URL                          Login
#  ─────────────────────────────────────────────────────────────────────
#  Supabase Studio  http://localhost:8000        supabase / admin123
#  Auth (gotrue)    http://localhost:9999/health
#  Inbucket Mail    http://localhost:9000        (view captured emails)
#  Kong (API GW)    http://localhost:8000
#  PostgREST        http://localhost:8000/rest/v1/
#  Direct DB        localhost:5433
#
# ═══════════════════════════════════════════════════════════════════════════
# 🧠 INSTRUCTIONS FOR ANOTHER AI
# ═══════════════════════════════════════════════════════════════════════════
#
# ── 1. DATABASE CONNECTION ─────────────────────────────────────────────
#  Host: localhost    Port: 5433    User: postgres
#  Pass: postgres     DB:   postgres
#
#  ⚠  PORT 5432 = Supavisor (pooler) — requires tenant ID in username.
#      Use PORT 5433 for DIRECT PostgreSQL connection.
#
#  ⚠  TABLE NAMES ARE QUOTED:
#      Correct:   SELECT * FROM public."Users"
#      Wrong:     SELECT * FROM public.Users
#
#  ⚠  AUTO-INCREMENT SEQUENCES can fall out of sync when seeding.
#      Fix:   SELECT setval('"Users_id_seq"', (SELECT MAX(id) FROM "Users"))
#
# ── 2. SMTP / EMAIL ────────────────────────────────────────────────────
#  This env sends emails via Gmail SMTP (smtp.gmail.com:587).
#  SMTP_PASS must be a Gmail App Password (not the regular password).
#  Generate at: https://myaccount.google.com/apppasswords
#
#  Inbucket (local email catcher) also runs on port 2500 for debugging.
#  View captured test emails at http://localhost:9000
#
# ── 3. GOOGLE OAUTH ────────────────────────────────────────────────────
#  Redirect URI:  http://localhost:8000/auth/v1/callback
#  Credentials from Google Cloud Console → APIs & Services → Credentials
#  OAuth 2.0 Web Client type.
#
#  ⚠  After changing Google OAuth config, RECREATE the auth container:
#      docker compose up -d --force-recreate auth
#      THIS CLEARS ALL SESSIONS — users must log in again.
#
# ── 4. AUTH CONTAINER RECREATION ───────────────────────────────────────
#  Any env change to the auth service requires --force-recreate:
#    docker compose up -d --force-recreate auth
#  This clears all active sessions (users re-login required).
#
# ── 5. TLS CERT FOR EMAIL ──────────────────────────────────────────────
#  Go 1.25+ requires STARTTLS for non-localhost SMTP.
#  A self-signed CA cert is mounted into the auth container at:
#    volumes/auth/ca-certificates.crt
#  Combined bundle = system CAs + Inbucket CA for development.
#
# ── 6. SEQUELIZE / BACKEND ─────────────────────────────────────────────
#  Backend config file: backend/src/config/database.js
#  Sequelize config:    backend/config/config.js
#  Both read from backend/.env (env vars).
#  Connection uses port 5433 (direct), SSL disabled.
#
# ═══════════════════════════════════════════════════════════════════════════
# ENVIRONMENT VARIABLES
# ═══════════════════════════════════════════════════════════════════════════

############
# Docker compose override files to layer on top of docker-compose.yml.
COMPOSE_FILE=docker-compose.yml

############
# Secrets
############

# Postgres
POSTGRES_PASSWORD=postgres

# Legacy symmetric HS256 key
JWT_SECRET=your-jwt-secret-at-least-32-chars

# Legacy API keys (HS256-signed JWTs)
ANON_KEY=your-anon-key
SERVICE_ROLE_KEY=your-service-role-key

SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SECRET_KEY=
JWT_KEYS=
JWT_JWKS=

# Access to Dashboard
DASHBOARD_USERNAME=supabase
DASHBOARD_PASSWORD=admin123

# Used by Realtime and Supavisor
SECRET_KEY_BASE=your-secret-key-base-for-realtime

# Used by Supavisor
VAULT_ENC_KEY=your-32-character-encryption-key

# Used by Studio to access Postgres via postgres-meta
PG_META_CRYPTO_KEY=your-encryption-key-32-chars-min

# Analytics
LOGFLARE_PUBLIC_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-public
LOGFLARE_PRIVATE_ACCESS_TOKEN=your-super-secret-and-long-logflare-key-private

# Access to Storage via S3 protocol endpoint
S3_PROTOCOL_ACCESS_KEY_ID=your-s3-access-key-id
S3_PROTOCOL_ACCESS_KEY_SECRET=your-s3-access-key-secret

############
# URLs
############

SUPABASE_PUBLIC_URL=http://localhost:8000
API_EXTERNAL_URL=http://localhost:8000

############
# Database - Postgres configuration
############

POSTGRES_HOST=db
POSTGRES_DB=postgres
POSTGRES_PORT=5432

############
# Supavisor - Database pooler
############

POOLER_PROXY_PORT_TRANSACTION=6543
POOLER_DEFAULT_POOL_SIZE=20
POOLER_MAX_CLIENT_CONN=100
POOLER_TENANT_ID=your-tenant-id
POOLER_DB_POOL_SIZE=5

############
# Studio - Configuration for the Dashboard
############

STUDIO_DEFAULT_ORGANIZATION=Default Organization
STUDIO_DEFAULT_PROJECT=Default Project
OPENAI_API_KEY=sk-proj-xxxxxxxx

############
# Auth - Configuration for the authentication server
############

SITE_URL=http://localhost:3000
ADDITIONAL_REDIRECT_URLS=

JWT_EXPIRY=3600
DISABLE_SIGNUP=false

MAILER_URLPATHS_CONFIRMATION="/auth/v1/verify"
MAILER_URLPATHS_INVITE="/auth/v1/verify"
MAILER_URLPATHS_RECOVERY="/auth/v1/verify"
MAILER_URLPATHS_EMAIL_CHANGE="/auth/v1/verify"

ENABLE_EMAIL_SIGNUP=true
ENABLE_EMAIL_AUTOCONFIRM=true
SMTP_ADMIN_EMAIL=your-email@gmail.com
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_SENDER_NAME=Travel App
ENABLE_ANONYMOUS_USERS=false

ENABLE_PHONE_SIGNUP=true
ENABLE_PHONE_AUTOCONFIRM=true

# Google OAuth
GOOGLE_ENABLED=true
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_SECRET=your-google-oauth-secret

############
# Storage
############

GLOBAL_S3_BUCKET=stub
REGION=stub
MINIO_ROOT_USER=supa-storage
MINIO_ROOT_PASSWORD=secret1234
STORAGE_TENANT_ID=stub

############
# Functions
############

FUNCTIONS_VERIFY_JWT=false

############
# API - PostgREST
############

PGRST_DB_SCHEMAS=public,storage,graphql_public
PGRST_DB_MAX_ROWS=1000
PGRST_DB_EXTRA_SEARCH_PATH=public

############
# Logs and Analytics
############

DOCKER_SOCKET_LOCATION=/var/run/docker.sock
GOOGLE_PROJECT_ID=GOOGLE_PROJECT_ID
GOOGLE_PROJECT_NUMBER=GOOGLE_PROJECT_NUMBER

############
# API gateway
############

KONG_HTTP_PORT=8000
KONG_HTTPS_PORT=8443
ANON_KEY_ASYMMETRIC=
SERVICE_ROLE_KEY_ASYMMETRIC=

############
# imgproxy
############

IMGPROXY_AUTO_WEBP=true

############
# TLS Proxy
############

PROXY_DOMAIN=your-domain.example.com
CERTBOT_EMAIL=admin@example.com
